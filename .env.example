# ==============================================================================
# OpenBench Docker Configuration Environment Variables
# Rename this file to '.env' and adjust the values before running docker-compose.
# ==============================================================================

# --- Database Settings ---
DB_NAME=openbench
DB_USER=openbench_user
DB_PASSWORD=choose_a_secure_database_password
DB_ROOT_PASSWORD=choose_a_secure_root_password
DB_HOST=db
DB_PORT=3306

# --- Django Settings ---
# Generate a secure secret key, e.g. using: openssl rand -base64 32
SECRET_KEY=generate_a_random_django_secret_key_here
# Comma-separated list of allowed hostnames/IPs. Add your homelab IP 192.168.1.2
ALLOWED_HOSTS=192.168.1.2,localhost,127.0.0.1,proxy
# Comma-separated list of trusted origins for CSRF verification (required for Django 4.x behind a proxy)
CSRF_TRUSTED_ORIGINS=http://192.168.1.2:8080,http://localhost:8080,http://127.0.0.1:8080,http://192.168.1.2

# --- OpenBench Fork Settings ---
# The repository and branch the worker will pull to build client code and engines.
# Point this to your personal fork and desired branch!
OPENBENCH_REPO=https://github.com/znxftw/OpenBench
OPENBENCH_REF=master

# --- Worker Credentials ---
# These are the credentials the worker container will use to register and fetch games.
# Create this user in the Django Admin interface (http://192.168.1.2/admin) first.
WORKER_USER=homelab_worker
WORKER_PASSWORD=worker_secret_password
# The URL of the OpenBench server. Inside the docker network, the worker can connect
# directly to the proxy container.
SERVER_URL=http://proxy
# Number of CPU threads dedicated to running matches
WORKER_THREADS=2
